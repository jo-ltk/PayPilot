# PayPilot — local development (copy to .env.local)

NODE_ENV=development



# Database (Neon dev branch)

DATABASE_URL=postgresql://user:password@localhost:5432/settleflow_dev



# Shopify

SHOPIFY_API_KEY=

SHOPIFY_API_SECRET=

SCOPES=read_orders,read_all_orders

HOST=https://localhost:3000



# Security

ENCRYPTION_KEY=change-me-32-characters-minimum!!

SESSION_SECRET=change-me-32-characters-minimum!!



# Inngest

INNGEST_EVENT_KEY=

INNGEST_SIGNING_KEY=



# Observability (production — set in Vercel, optional in dev)

SENTRY_DSN=

BETTERSTACK_SOURCE_TOKEN=

POSTHOG_API_KEY=

POSTHOG_HOST=https://us.i.posthog.com

